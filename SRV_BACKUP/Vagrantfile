Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"
  config.vm.hostname = "srv-backup"

  # IP du serveur de sauvegarde
  config.vm.network "private_network", ip: "192.168.56.20"

  config.vm.provider "virtualbox" do |vb|
    vb.name = "SRV_BACKUP"
    vb.memory = 2048
    vb.cpus = 2
  end

  config.vm.provision "shell", inline: <<-SHELL
    set -e

    echo "[1/4] Mise à jour du système..."
    apt-get update -y
    apt-get upgrade -y

    echo "[2/4] Installation de BorgBackup et outils..."
    apt-get install -y borgbackup borgmatic openssh-server curl vim htop

    echo "[3/4] Création de l'utilisateur dédié aux sauvegardes..."
    if ! id "borguser" >/dev/null 2>&1; then
      useradd -m -s /bin/bash borguser
      echo 'borguser:BorgBackup2026!' | chpasswd
    fi

    # Création du dossier qui va recevoir les sauvegardes
    mkdir -p /srv/borg/mediaschool
    chown -R borguser:borguser /srv/borg
    chmod 700 /srv/borg

    # Dossier pour les clés SSH autorisées
    mkdir -p /home/borguser/.ssh
    chmod 700 /home/borguser/.ssh
    chown borguser:borguser /home/borguser/.ssh

    echo "[4/4] Configuration UFW..."
    apt-get install -y ufw
    ufw --force reset
    ufw default deny incoming
    ufw default allow outgoing
    ufw allow 22/tcp    # SSH (utilisé par BorgBackup)
    ufw allow 9100/tcp  # Node Exporter (pour Prometheus)
    ufw --force enable

    echo "[OK] SRV_BACKUP provisionné avec succès."
    echo "     → Dossier de sauvegarde : /srv/borg/mediaschool"
    echo "     → Utilisateur Borg      : borguser"
  SHELL
end
